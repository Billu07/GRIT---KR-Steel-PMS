generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  email     String?  @unique
  role      Role     @default(user)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tasks     Task[]   @relation("TaskCreator")

  @@map("users")
}

model EquipmentCategory {
  id          Int         @id @default(autoincrement())
  name        String      @unique
  description String?
  equipment   Equipment[]

  @@map("equipment_categories")
}

model Equipment {
  id                 Int                  @id @default(autoincrement())
  code               String               @unique
  name               String
  categoryId         Int
  location           String?
  description        String?
  status             EquipmentStatus      @default(active)
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  imageUrl           String?
  safetyMeasures     String?
  brand              String?
  capacity           String?
  model              String?
  runningHours       String?
  serialNumber       String?
  testCertApplied    String?
  testCertNumber     String?
  testCertValidity   String?
  serviceReportUrl   String?
  category           EquipmentCategory    @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  maintenanceHistory MaintenanceHistory[]
  tasks              Task[]

  @@map("equipment")
}

model Task {
  id                 Int                  @id @default(autoincrement())
  taskId             String               @unique
  taskName           String
  frequency          Frequency
  taskDetail         String?
  equipmentId        Int
  createdBy          Int
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  criticality        Criticality          @default(medium)
  lastCompletedDate  DateTime?
  nextDueDate        DateTime?
  estimatedHours     Int?
  runningHours       Int                  @default(0)
  maintenanceHistory MaintenanceHistory[]
  creator            User                 @relation("TaskCreator", fields: [createdBy], references: [id])
  equipment          Equipment            @relation(fields: [equipmentId], references: [id], onDelete: Cascade)

  @@map("tasks")
}

model MaintenanceHistory {
  id                 Int             @id @default(autoincrement())
  equipmentId        Int
  performedAt        DateTime        @default(now())
  createdAt          DateTime        @default(now())
  informationDate    DateTime?
  maintenanceDate    DateTime?
  maintenanceDetails String?
  problemDescription String?
  problemType        ProblemType?
  remarks            String?
  serviceEndDate     DateTime?
  serviceStartDate   DateTime?
  solutionDetails    String?
  type               MaintenanceType @default(scheduled)
  usedParts          String?
  workType           WorkType?
  taskId             Int?
  estimatedHours     Int?
  runningHours       Int?
  targetDate         DateTime?
  targetHours        Int?
  equipment          Equipment       @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  task               Task?           @relation(fields: [taskId], references: [id])

  @@map("maintenance_history")
}

model Inventory {
  id            Int      @id @default(autoincrement())
  name          String
  quantity      String?
  description   String?
  swl           String?
  certificateNo String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("inventory")
}

enum Role {
  admin
  user
}

enum EquipmentStatus {
  active
  inactive
  maintenance
  retired
}

enum Frequency {
  daily
  weekly
  monthly
  quarterly     @map("3-monthly")
  semi_annually @map("6-monthly")
  yearly
  five_yearly   @map("5-yearly")
  hourly
  fifteen_days  @map("15-days")
}

enum Criticality {
  low
  medium
  high
}

enum MaintenanceType {
  scheduled
  predictive
  corrective
}

enum WorkType {
  new
  rework
}

enum ProblemType {
  major
  minor
}
